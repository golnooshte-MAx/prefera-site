---
import '../styles/global.css';
import { faqs, answerBlocks } from '../data/faqs.js';

const {
  title = "AI visibility for aesthetic clinics | Prefera",
  description = "Prefera helps independent aesthetic clinics get recommended by ChatGPT, Perplexity, and Google AI Overviews. Free AI Visibility Read, no commitment.",
} = Astro.props;
const siteUrl = "https://prefera.dev";

// Per-page canonical / og:url (avoids every page canonicalizing to the homepage).
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const isHome = Astro.url.pathname === "/";
const ogImage = `${siteUrl}/og-image.jpg`;
// Freshness signal for AI/search. Bump when content materially changes.
const lastUpdated = "2026-07-09";

// FAQ structured data only belongs on the page that actually shows the FAQ.
// The FAQ accordion plus the definitional Answers section, both visible on
// the homepage, feed one FAQPage node (Google allows one per page).
const faqPage = {
  "@type": "FAQPage",
  "mainEntity": [...faqs, ...answerBlocks].map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Prefera",
      "description": description
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "datePublished": "2026-06-22",
      "dateModified": lastUpdated
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Prefera",
      "url": siteUrl,
      "founder": { "@type": "Person", "name": "Golnoosh" },
      "address": { "@type": "PostalAddress", "addressLocality": "Utrecht", "addressCountry": "NL" }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Golnoosh",
      "jobTitle": "Founder",
      "worksFor": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      "name": "Prefera",
      "description": "AI visibility (AEO) for independent aesthetic clinics across the UK, EU, US, and Canada. Off-site authority building so AI assistants recommend your clinic.",
      "address": { "@type": "PostalAddress", "addressLocality": "Utrecht", "addressCountry": "NL" },
      "areaServed": ["GB", "EU", "US", "CA"],
      "founder": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Service",
      "serviceType": ["AI Search Visibility", "Answer Engine Optimization", "Local SEO", "Google Business Profile Management", "AI Voice Assistant"],
      "provider": { "@id": `${siteUrl}/#organization` },
      "areaServed": ["GB", "EU", "US", "CA"],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Visibility services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Google Business Profile management", "description": "Complete, active profiles that rank in the local map pack: photos, posts, reviews, and categories, handled weekly." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Local SEO", "description": "Structured data, local citations, consistent NAP, review velocity, and city-level landing pages." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI search visibility", "description": "Making a business recognizable and citable by ChatGPT, Perplexity, and Google AI Overviews." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "AI voice assistant", "description": "Answers every call, books appointments into the calendar, and speaks the customer's language." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Search-ready websites", "description": "Fast Core Web Vitals, proper schema markup, location pages that rank, and content structured for search engines and AI crawlers." } }
        ]
      }
    },
    ...(isHome ? [faqPage] : [])
  ]
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0C0C0E" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <slot />
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    const blindsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.3, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.blinds-reveal').forEach(el => blindsObserver.observe(el));
  </script>
  <script>
    const counters = document.querySelectorAll('[data-count]');
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.getAttribute('data-count'));
          const suffix = el.getAttribute('data-suffix') || '';
          let current = 0;
          const duration = 1500;
          const step = target / (duration / 16);
          const timer = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(timer);
            }
            el.textContent = Math.round(current) + suffix;
          }, 16);
          countObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(el => countObserver.observe(el));
  </script>
  <script>
    const sections = document.querySelectorAll('[data-scroll-bg]');
    // The merged #problem section (formerly reveal + stats) maps to a single
    // dark color stop. No CSS var is defined for it, so it falls back here.
    const bgFallback = { problem: '#1a1a24' };
    const bgObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const bgKey = entry.target.getAttribute('data-scroll-bg');
          const color = getComputedStyle(document.documentElement).getPropertyValue(`--scroll-bg-${bgKey}`).trim() || bgFallback[bgKey];
          if (color) {
            document.body.style.backgroundColor = color;
          }
        }
      });
    }, {
      threshold: 0,
      rootMargin: '-40% 0px -40% 0px'
    });
    sections.forEach(section => bgObserver.observe(section));

    // Supplementary trigger: light the body to the services color EARLIER, while
    // the user is still in the bottom ~20% of the (opaque) stats section above, so
    // the services header's dark text is never rendered on a dark body. The opaque
    // stats background hides this early change until it scrolls away. The main
    // observer above is left unchanged.
    const servicesSection = document.querySelector('[data-scroll-bg="services"]');
    if (servicesSection) {
      const servicesColor = getComputedStyle(document.documentElement).getPropertyValue('--scroll-bg-services').trim();
      const earlyServicesObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && servicesColor) {
            document.body.style.backgroundColor = servicesColor;
          }
        });
      }, {
        threshold: 0,
        rootMargin: '-80% 0px 0px 0px'
      });
      earlyServicesObserver.observe(servicesSection);
    }
  </script>
</body>
</html>
