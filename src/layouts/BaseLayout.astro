---
const {
  title = "Prefera — Your customers are searching. Can they find you?",
  description = "Prefera makes local businesses visible across Google Search, Google Business Profile, ChatGPT, Perplexity, and AI Overviews. Audit, fix, maintain.",
} = Astro.props;
const siteUrl = "https://prefera.dev";

// Per-page canonical / og:url (avoids every page canonicalizing to the homepage).
const canonical = new URL(Astro.url.pathname, siteUrl).href;
const isHome = Astro.url.pathname === "/";
const ogImage = `${siteUrl}/og-image.png`;
// Freshness signal for AI/search. Bump when content materially changes.
const lastUpdated = "2026-06-22";

// FAQ structured data only belongs on the page that actually shows the FAQ.
const faqPage = {
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How fast will I see results?", "acceptedAnswer": { "@type": "Answer", "text": "Google Business Profile improvements show up in the map pack within 2 to 4 weeks. Local SEO ranking gains for service-area keywords take 8 to 12 weeks. AI search citations (ChatGPT, Perplexity) can appear within days once we structure your content correctly." }},
    { "@type": "Question", "name": "Do I have to sign a long contract?", "acceptedAnswer": { "@type": "Answer", "text": "No. Month-to-month. Cancel anytime with 30 days notice. The audit is a one-time fee, the retainer is rolling. If we are not earning our keep, you should not be paying us." }},
    { "@type": "Question", "name": "I already have a website. Do I need a new one?", "acceptedAnswer": { "@type": "Answer", "text": "Almost never. We work with what you have. The fixes happen on Google Business Profile, your existing pages, structured data, and AI-readable content. A rebuild is the last resort, not the first move." }},
    { "@type": "Question", "name": "Do you work with businesses outside the Netherlands?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Local SEO and GBP optimization are location-agnostic. Currently serving NL, Belgium, and English-speaking clients across Europe and North America. AI visibility work is global by definition." }},
    { "@type": "Question", "name": "How do you measure AI search visibility?", "acceptedAnswer": { "@type": "Answer", "text": "We track citations across ChatGPT, Perplexity, Google AI Overviews, and Claude for a defined set of queries relevant to your business. You get a monthly visibility score and the actual prompts where you appear or do not. No black-box dashboards." }}
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      "url": siteUrl,
      "name": "Prefera",
      "description": description
    },
    {
      "@type": "WebPage",
      "@id": `${canonical}#webpage`,
      "url": canonical,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "datePublished": "2026-06-22",
      "dateModified": lastUpdated
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Prefera",
      "url": siteUrl,
      "founder": { "@type": "Person", "name": "Golnoosh" },
      "address": { "@type": "PostalAddress", "addressLocality": "Utrecht", "addressCountry": "NL" }
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      "name": "Golnoosh",
      "jobTitle": "Founder",
      "worksFor": { "@id": `${siteUrl}/#organization` }
    },
    {
      "@type": "LocalBusiness",
      "@id": `${siteUrl}/#localbusiness`,
      "name": "Prefera",
      "description": "Local SEO, Google Business Profile management, and AI search visibility for European service businesses.",
      "address": { "@type": "PostalAddress", "addressLocality": "Utrecht", "addressCountry": "NL" },
      "areaServed": ["NL", "EU"],
      "founder": { "@id": `${siteUrl}/#person` }
    },
    {
      "@type": "Service",
      "serviceType": ["Local SEO", "Google Business Profile Management", "AI Search Visibility", "AI Voice Assistant"],
      "provider": { "@id": `${siteUrl}/#organization` },
      "areaServed": ["NL", "EU"]
    },
    ...(isHome ? [faqPage] : []),
    {
      "@type": "BreadcrumbList",
      "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl }]
    }
  ]
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="theme-color" content="#0C0C0E" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
  <slot />
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    const blindsObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.3, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.blinds-reveal').forEach(el => blindsObserver.observe(el));
  </script>
  <script>
    const counters = document.querySelectorAll('[data-count]');
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.getAttribute('data-count'));
          const suffix = el.getAttribute('data-suffix') || '';
          let current = 0;
          const duration = 1500;
          const step = target / (duration / 16);
          const timer = setInterval(() => {
            current += step;
            if (current >= target) {
              current = target;
              clearInterval(timer);
            }
            el.textContent = Math.round(current) + suffix;
          }, 16);
          countObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    counters.forEach(el => countObserver.observe(el));
  </script>
  <script>
    const sections = document.querySelectorAll('[data-scroll-bg]');
    // The merged #problem section (formerly reveal + stats) maps to a single
    // dark color stop. No CSS var is defined for it, so it falls back here.
    const bgFallback = { problem: '#1a1a24' };
    const bgObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const bgKey = entry.target.getAttribute('data-scroll-bg');
          const color = getComputedStyle(document.documentElement).getPropertyValue(`--scroll-bg-${bgKey}`).trim() || bgFallback[bgKey];
          if (color) {
            document.body.style.backgroundColor = color;
          }
        }
      });
    }, {
      threshold: 0,
      rootMargin: '-40% 0px -40% 0px'
    });
    sections.forEach(section => bgObserver.observe(section));

    // Supplementary trigger: light the body to the services color EARLIER, while
    // the user is still in the bottom ~20% of the (opaque) stats section above, so
    // the services header's dark text is never rendered on a dark body. The opaque
    // stats background hides this early change until it scrolls away. The main
    // observer above is left unchanged.
    const servicesSection = document.querySelector('[data-scroll-bg="services"]');
    if (servicesSection) {
      const servicesColor = getComputedStyle(document.documentElement).getPropertyValue('--scroll-bg-services').trim();
      const earlyServicesObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && servicesColor) {
            document.body.style.backgroundColor = servicesColor;
          }
        });
      }, {
        threshold: 0,
        rootMargin: '-80% 0px 0px 0px'
      });
      earlyServicesObserver.observe(servicesSection);
    }
  </script>
</body>
</html>
