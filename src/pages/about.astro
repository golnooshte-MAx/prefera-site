---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About Golnoosh, founder of Prefera"
  description="Prefera is a one-person AEO studio in Utrecht run by Golnoosh, helping aesthetic clinics in the UK and EU get recommended by AI assistants."
>
  <Nav />
  <main id="main" class="about-page">
    <div class="about-wrapper">
      <h1>The person behind Prefera.</h1>

      <p class="about-lead">Prefera is a one-person AEO studio in Utrecht, run by Golnoosh, a performance marketer with more than ten years across growth, paid search and social, and data analysis. She helps independent aesthetic clinics in the UK and EU become the answer AI assistants give.</p>

      <h2>Background</h2>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-title">Founder, Prefera</div>
          <div class="timeline-date">2026 to present</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-title">Performance Marketing Specialist, 5CA</div>
          <div class="timeline-date">2022 to 2025</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-title">Growth and Performance Marketing, Cocoroco</div>
          <div class="timeline-date">2022 to 2023</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-title">Growth Marketer, Shatel Mobile</div>
          <div class="timeline-date">2019 to 2021</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-title">Digital Marketing Specialist, Yara Information Technology</div>
          <div class="timeline-date">2017 to 2018</div>
        </div>
        <div class="timeline-item">
          <div class="timeline-title">Sales and marketing roles, Respina Networks and Shatel</div>
          <div class="timeline-date">2012 to 2017</div>
        </div>
      </div>

      <p>Campaigns run on Google, Meta, TikTok, and LinkedIn across EMEA, APAC, and LATAM markets. Analytics in Google Analytics and Looker Studio. Languages: English, Dutch, Farsi.</p>

      <p>Prefera is advised on product and technology by Max, a senior technical product manager with more than ten years in e-commerce, payments, and AI products.</p>

      <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=about" class="btn-primary btn-accent">Book a free audit</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .about-page {
    background: var(--bg-primary);
    min-height: 100vh;
    padding: 6rem 1.5rem;
  }

  .about-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  h1 {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  .about-lead {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  h2 {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--text-primary);
    margin: 2.5rem 0 1.5rem;
    line-height: 1.3;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 2rem;
  }

  .timeline-item {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .timeline-item:last-child {
    border-bottom: none;
  }

  .timeline-title {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-primary);
    flex: 1;
  }

  .timeline-date {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--text-secondary);
    margin-left: 2rem;
    text-align: right;
    white-space: nowrap;
  }

  p {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .btn-primary {
    margin-top: 2rem;
  }

  @media (max-width: 640px) {
    .about-page {
      padding: 3rem 1.5rem;
    }

    .timeline-date {
      margin-left: 1rem;
    }
  }
</style>
