---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const siteUrl = "https://prefera.dev";

const offerCatalogSchema = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Prefera Services",
  "provider": {
    "@id": `${siteUrl}/#organization`
  },
  "itemListElement": [
    {
      "@type": "Offer",
      "name": "Starter",
      "price": "490",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "description": "Visibility monitoring across ChatGPT, Perplexity, Google AI Overviews, and Claude. Quarterly AI Visibility Read refresh. Directory and citation foundation."
    },
    {
      "@type": "Offer",
      "name": "Growth",
      "price": "1190",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "description": "Everything in Starter. Monthly content mirroring the queries patients ask AI. Review platform program."
    },
    {
      "@type": "Offer",
      "name": "Elite",
      "price": "2500",
      "priceCurrency": "EUR",
      "availability": "https://schema.org/InStock",
      "description": "Everything in Growth. Full off-site authority campaign with press outreach and community presence. Multi-treatment coverage."
    }
  ]
};
---

<BaseLayout
  title="Services and pricing | Prefera"
  description="Three month-to-month tiers for clinic AI visibility: Starter EUR 490, Growth EUR 1,190, Elite EUR 2,500. Starts with a free AI Visibility Read."
>
  <script type="application/ld+json" set:html={JSON.stringify(offerCatalogSchema)} />
  <Nav />
  <main id="main" class="services-page">
    <div class="services-wrapper">
      <h1>Services and pricing.</h1>

      <p class="services-lead">Prefera has three month-to-month tiers. No long contracts, cancel anytime with 30 days notice. Every engagement starts with a free AI Visibility Read so you see where you stand before spending anything.</p>

      <div class="pricing-cards">
        <div class="pricing-card">
          <div class="tier-name">Starter</div>
          <div class="tier-price">EUR 490<span class="tier-period">/month</span></div>
          <ul class="tier-features">
            <li>Visibility monitoring across ChatGPT, Perplexity, Google AI Overviews, and Claude</li>
            <li>Quarterly AI Visibility Read refresh</li>
            <li>Directory and citation foundation</li>
          </ul>
        </div>

        <div class="pricing-card pricing-featured">
          <div class="tier-name">Growth</div>
          <div class="tier-price">EUR 1,190<span class="tier-period">/month</span></div>
          <ul class="tier-features">
            <li>Everything in Starter</li>
            <li>Monthly content mirroring the queries patients ask AI</li>
            <li>Review platform program</li>
          </ul>
        </div>

        <div class="pricing-card">
          <div class="tier-name">Elite</div>
          <div class="tier-price">EUR 2,500<span class="tier-period">/month</span></div>
          <ul class="tier-features">
            <li>Everything in Growth</li>
            <li>Full off-site authority campaign: press outreach and community presence</li>
            <li>Multi-treatment coverage</li>
          </ul>
        </div>
      </div>

      <p class="pricing-note">First citations typically appear in 6 to 9 weeks. No result guarantees, and be wary of anyone who offers them.</p>

      <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=services-page" class="btn-primary btn-accent">Book a free audit</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .services-page {
    background: var(--bg-primary);
    min-height: 100vh;
    padding: 6rem 1.5rem;
  }

  .services-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  h1 {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.2;
  }

  .services-lead {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .pricing-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .pricing-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    background: white;
    transition: all 200ms ease;
  }

  .pricing-card:hover {
    border-color: var(--accent-soft);
    box-shadow: 0 4px 12px rgba(95, 75, 139, 0.08);
  }

  .pricing-featured {
    border-color: var(--accent);
    background: linear-gradient(135deg, rgba(95, 75, 139, 0.03), rgba(95, 75, 139, 0.06));
  }

  .tier-name {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .tier-price {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .tier-period {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--text-secondary);
    margin-left: 0.5rem;
  }

  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tier-features li {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }

  .tier-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .pricing-note {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: 8px;
  }

  .btn-primary {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .services-page {
      /* Top padding must clear the 72px fixed nav */
      padding: 5.5rem 1.5rem 3rem;
    }
  }
</style>
