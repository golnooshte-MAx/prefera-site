---
---
<section id="proof" data-scroll-bg="proof">
  <div class="proof-glow"></div>
  <div class="proof-inner">
    <span class="eyebrow">WHAT YOU GET</span>
    <h2>No mystery. You see everything.</h2>
    <p class="proof-subtext">Every client gets a visibility audit on day one, a clear action plan, and a monthly report that shows exactly what moved. No vanity metrics. No vague updates.</p>

    <div class="deliverables-grid">

      <!-- CARD 1: Before/After Score -->
      <div class="deliverable-card deliverable-wide fade-up">
        <div class="deliverable-label">YOUR TRAJECTORY</div>
        <div class="before-after">
          <div class="score-state score-before">
            <span class="score-state-label">BEFORE</span>
            <div class="mini-scorecard">
              <div class="mini-score-row">
                <span class="mini-score-name">Aster Aesthetics</span>
                <div class="mini-score-ring-container">
                  <svg class="mini-ring" viewBox="0 0 60 60" aria-hidden="true">
                    <circle cx="30" cy="30" r="24" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="4"/>
                    <circle cx="30" cy="30" r="24" fill="none" stroke="#F59E0B" stroke-width="4" stroke-linecap="round" stroke-dasharray="108.6 150.8" transform="rotate(-90 30 30)"/>
                  </svg>
                  <span class="mini-ring-number">72</span>
                </div>
              </div>
              <div class="mini-channels">
                <div class="mini-ch"><span>GBP</span><span class="mini-pill pill-strong">STRONG</span></div>
                <div class="mini-ch"><span>Local SEO</span><span class="mini-pill pill-improving">IMPROVING</span></div>
                <div class="mini-ch"><span>ChatGPT</span><span class="mini-pill pill-at-risk">AT RISK</span></div>
                <div class="mini-ch"><span>Perplexity</span><span class="mini-pill pill-not-found">NOT FOUND</span></div>
              </div>
            </div>
          </div>

          <div class="score-arrow">→</div>

          <div class="score-state score-after">
            <span class="score-state-label">AFTER 90 DAYS</span>
            <div class="mini-scorecard">
              <div class="mini-score-row">
                <span class="mini-score-name">Aster Aesthetics</span>
                <div class="mini-score-ring-container">
                  <svg class="mini-ring" viewBox="0 0 60 60" aria-hidden="true">
                    <circle cx="30" cy="30" r="24" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="4"/>
                    <circle cx="30" cy="30" r="24" fill="none" stroke="#22C55E" stroke-width="4" stroke-linecap="round" stroke-dasharray="139 150.8" transform="rotate(-90 30 30)"/>
                  </svg>
                  <span class="mini-ring-number">92</span>
                </div>
              </div>
              <div class="mini-channels">
                <div class="mini-ch"><span>GBP</span><span class="mini-pill pill-strong">STRONG</span></div>
                <div class="mini-ch"><span>Local SEO</span><span class="mini-pill pill-strong">STRONG</span></div>
                <div class="mini-ch"><span>ChatGPT</span><span class="mini-pill pill-improving">CITED</span></div>
                <div class="mini-ch"><span>Perplexity</span><span class="mini-pill pill-improving">CITED</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- CARD 2: Audit Report -->
      <div class="deliverable-card fade-up">
        <div class="deliverable-label">DAY 1 DELIVERABLE</div>
        <div class="deliverable-title">Visibility audit report</div>
        <div class="deliverable-checklist">
          <div class="check-item"><span class="check-icon">✓</span> AI visibility score across 5 channels</div>
          <div class="check-item"><span class="check-icon">✓</span> Competitor comparison (top 3 in your city)</div>
          <div class="check-item"><span class="check-icon">✓</span> Prioritized fix list with effort estimates</div>
          <div class="check-item"><span class="check-icon">✓</span> GBP optimization checklist</div>
          <div class="check-item"><span class="check-icon">✓</span> Schema and structured data audit</div>
        </div>
        <div class="deliverable-note">Free. No commitment. Delivered in 48 hours.</div>
      </div>

      <!-- CARD 3: Monthly Report -->
      <div class="deliverable-card fade-up">
        <div class="deliverable-label">EVERY MONTH</div>
        <div class="deliverable-title">Performance report</div>
        <div class="deliverable-checklist">
          <div class="check-item"><span class="check-icon">✓</span> Ranking changes for your target keywords</div>
          <div class="check-item"><span class="check-icon">✓</span> AI citation tracking (ChatGPT, Perplexity)</div>
          <div class="check-item"><span class="check-icon">✓</span> GBP insights: views, clicks, calls</div>
          <div class="check-item"><span class="check-icon">✓</span> Actions taken this month</div>
          <div class="check-item"><span class="check-icon">✓</span> Next month's priorities</div>
        </div>
        <div class="deliverable-note">Plus a 30-minute call to walk through it.</div>
      </div>

    </div>
  </div>
</section>

<style>
  #proof {
    position: relative;
    z-index: 1;
    padding: 5rem 1.5rem;
    overflow: hidden;
  }

  /* Subtle lavender glow behind the section */
  .proof-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(ellipse 80% 50% at 50% 30%, rgba(196,181,253,0.12) 0%, transparent 70%);
  }

  .proof-inner {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .proof-inner .eyebrow {
    display: block;
    text-align: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #5F4B8B;
  }

  .proof-inner h2 {
    text-align: center;
    font-family: 'Fraunces Variable', serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    color: #1a1a1f;
    line-height: 1.15;
    margin-top: 1rem;
  }

  .proof-subtext {
    text-align: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 15px;
    color: #6b7280;
    line-height: 1.6;
    margin-top: 0.75rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .deliverables-grid {
    margin-top: 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .deliverable-wide {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, #141420 0%, #1a1a2e 50%, #141420 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }
  /* Subtle aurora glow inside the trajectory card */
  .deliverable-wide::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(95, 75, 139, 0.15) 0%, transparent 60%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }
  .deliverable-wide .deliverable-label { color: rgba(255, 255, 255, 0.4); }

  .deliverable-card:not(.deliverable-wide) {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04), 0 0 0 1px rgba(95, 75, 139, 0.04);
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Decorative accent stripe at the top of each plain card */
  .deliverable-card:not(.deliverable-wide)::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #5F4B8B, #8B7FD4, #5F4B8B);
    opacity: 0.6;
  }
  @media (hover: hover) {
    .deliverable-card:not(.deliverable-wide):hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 32px rgba(95, 75, 139, 0.1), 0 0 0 1px rgba(95, 75, 139, 0.08);
      border-color: rgba(95, 75, 139, 0.12);
    }
  }

  .deliverable-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #9ca3af;
    margin-bottom: 1rem;
  }

  .deliverable-title {
    font-family: 'Fraunces Variable', serif;
    font-weight: 400;
    font-size: 1.35rem;
    color: #1a1a1f;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  /* ---- Before/After card ---- */
  .before-after {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
  }

  .score-state {
    flex: 1;
    max-width: 400px;
  }

  .score-state-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    display: block;
    margin-bottom: 0.75rem;
  }

  .mini-scorecard {
    background: #1a1a24;
    border-radius: 12px;
    padding: 1.25rem;
    border: 1px solid rgba(255,255,255,0.06);
  }
  /* Before/after tints reinforce the improvement story */
  .score-before .mini-scorecard {
    background: rgba(20, 18, 28, 0.9);
    border: 1px solid rgba(245, 158, 11, 0.15);
    box-shadow: 0 4px 20px rgba(245, 158, 11, 0.05);
  }
  .score-after .mini-scorecard {
    background: rgba(20, 18, 28, 0.9);
    border: 1px solid rgba(34, 197, 94, 0.2);
    box-shadow: 0 4px 20px rgba(34, 197, 94, 0.08);
  }

  .mini-score-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .mini-score-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: white;
  }

  .mini-score-ring-container {
    position: relative;
    width: 48px;
    height: 48px;
  }

  .mini-ring {
    width: 100%;
    height: 100%;
  }

  .mini-ring-number {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: white;
  }

  .mini-channels {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .mini-ch {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    padding: 0.3rem 0;
  }

  .mini-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 12px;
    border: 1px solid transparent;
  }

  /* Pill color classes (same palette as the main scorecard, redefined in scope) */
  .pill-strong {
    color: #22C55E;
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
  }
  .pill-improving {
    color: #60A5FA;
    background: rgba(96, 165, 250, 0.1);
    border-color: rgba(96, 165, 250, 0.2);
  }
  .pill-at-risk {
    color: #F59E0B;
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.25);
  }
  .pill-not-found {
    color: #EF4444;
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.25);
  }

  .score-arrow {
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 300;
    flex-shrink: 0;
    animation: arrow-pulse 2s ease-in-out infinite;
  }
  @keyframes arrow-pulse {
    0%, 100% { opacity: 0.3; transform: translateX(0); }
    50% { opacity: 0.6; transform: translateX(4px); }
  }

  /* ---- Checklist cards ---- */
  .deliverable-checklist {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .check-item {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: #374151;
    line-height: 1.5;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
  }
  .check-item:last-child {
    border-bottom: none;
  }

  .check-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.1);
    color: #22C55E;
    font-size: 11px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .deliverable-note {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: #5F4B8B;
    font-style: normal;
    font-weight: 500;
  }

  /* ---- Entrance animation ---- */
  .fade-up {
    opacity: 0;
    transform: translateY(24px);
  }
  .fade-up.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .deliverables-grid {
      grid-template-columns: 1fr;
    }
    .before-after {
      flex-direction: column;
      gap: 1rem;
    }
    .score-arrow {
      transform: rotate(90deg);
    }
    .score-state {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-up { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  (function() {
    const items = document.querySelectorAll('#proof .fade-up');
    if (!items.length) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    items.forEach(el => observer.observe(el));
  })();
</script>
