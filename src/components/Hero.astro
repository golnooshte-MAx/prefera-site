---
---
<section class="hero">
  <video autoplay muted loop playsinline poster="/hero-bg.jpg" class="hero-video">
    <source src="/hero-video.mp4" type="video/mp4" />
  </video>

  <!-- Multi-layered overlay: above the video, below the text content -->
  <div class="hero-overlay hero-overlay-base"></div>
  <div class="hero-overlay hero-overlay-vignette"></div>
  <div class="hero-overlay hero-overlay-bottom"></div>

  <div class="hero-inner container">
    <h1 class="hero-headline">
      <span class="hero-line-1">
        <span class="hero-serif">Your patients are asking AI.</span>
      </span>
      <span class="hero-line-2">
        <span class="hero-sans">Is your clinic</span> <span class="hero-serif">the answer?</span>
      </span>
    </h1>
    <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=hero" class="hero-cta">Get your free AI Visibility Read</a>
    <p class="hero-subline">Free audit · No commitment · Delivered in 48 hours</p>
  </div>

  <div class="scroll-indicator">
    <div class="scroll-mouse">
      <div class="scroll-dot"></div>
    </div>
  </div>
</section>

<!-- @property declarations cannot be scoped in Astro, so they live in a global block -->
<style is:global>
  @property --gradient-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @property --gradient-angle-offset {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @property --gradient-percent {
    syntax: "<percentage>";
    initial-value: 5%;
    inherits: false;
  }

  @property --gradient-shine {
    syntax: "<color>";
    initial-value: white;
    inherits: false;
  }
</style>

<style>
  .hero {
    position: relative;
    z-index: 1;
    background-color: var(--bg-dark);
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 72px;
    overflow: hidden;
  }
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.12);
    z-index: 0;
  }

  /* ---- Overlay layers (z above video, below text) ---- */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  /* Layer 1 — base darkening for minimum contrast everywhere */
  .hero-overlay-base {
    background: rgba(12, 12, 14, 0.35);
  }
  /* Layer 2 — center vignette protecting the headline text */
  .hero-overlay-vignette {
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(12, 12, 14, 0.50) 0%, rgba(12, 12, 14, 0.15) 60%, transparent 100%);
  }
  /* Layer 3 — bottom gradient fading into the next section */
  .hero-overlay-bottom {
    background: linear-gradient(to top, rgba(12, 12, 14, 0.9) 0%, rgba(12, 12, 14, 0.4) 25%, transparent 50%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  /* ---- Glass shimmer headline ---- */
  .hero-headline {
    text-align: center;
    line-height: 1.1;
    font-size: clamp(2.2rem, 6vw, 4.5rem);
    color: transparent;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 1) 0%,
      rgba(255, 255, 255, 0.4) 25%,
      rgba(255, 255, 255, 0.1) 45%,
      rgba(255, 255, 255, 0.9) 55%,
      rgba(255, 255, 255, 0.2) 75%,
      rgba(255, 255, 255, 1) 100%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.25);
    filter: drop-shadow(0 12px 30px rgba(0, 0, 0, 0.35)) drop-shadow(0 4px 8px rgba(0, 0, 0, 0.2));
    animation: hero-shimmer 8s linear infinite;
    max-width: 900px;
    margin: 0 auto;
  }
  @keyframes hero-shimmer {
    0% { background-position: 200% center; }
    100% { background-position: 0% center; }
  }
  .hero-line-1,
  .hero-line-2 {
    display: block;
  }
  .hero-serif {
    font-family: 'Fraunces Variable', serif;
    font-weight: 300;
    font-style: italic;
  }
  .hero-sans {
    font-family: 'Inter Variable', sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-style: normal;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-headline { animation: none; }
  }
  @media (max-width: 768px) {
    .hero-headline {
      font-size: clamp(1.8rem, 8vw, 2.8rem);
      -webkit-text-stroke: 0.75px rgba(255, 255, 255, 0.2);
    }
  }

  /* ---- Shiny animated CTA ---- */
  .hero-cta {
    --shiny-bg: rgba(95, 75, 139, 0.35);
    --shiny-bg-subtle: rgba(30, 28, 35, 0.8);
    --shiny-fg: #ffffff;
    --shiny-highlight: #5F4B8B;
    --shiny-highlight-subtle: #8B7FD4;
    --shiny-duration: 3s;
    --shiny-shadow-size: 2px;
    --shiny-transition: 800ms cubic-bezier(0.25, 1, 0.5, 1);

    margin-top: 2.5rem;
    isolation: isolate;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    outline-offset: 4px;
    padding: 1.15rem 3rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 17px;
    font-weight: 500;
    letter-spacing: 0.01em;
    line-height: 1.2;
    border: 1px solid transparent;
    border-radius: 50px;
    color: var(--shiny-fg);
    text-decoration: none;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background:
      linear-gradient(var(--shiny-bg), var(--shiny-bg)) padding-box,
      conic-gradient(
        from calc(var(--gradient-angle) - var(--gradient-angle-offset)),
        transparent,
        var(--shiny-highlight) var(--gradient-percent),
        var(--gradient-shine) calc(var(--gradient-percent) * 2),
        var(--shiny-highlight) calc(var(--gradient-percent) * 3),
        transparent calc(var(--gradient-percent) * 4)
      ) border-box;
    box-shadow: inset 0 0 0 1px var(--shiny-bg-subtle), 0 0 20px rgba(95, 75, 139, 0.25), 0 0 60px rgba(95, 75, 139, 0.1);
    transition: var(--shiny-transition);
    transition-property: --gradient-angle-offset, --gradient-percent, --gradient-shine;
    animation: cta-pulse 3s ease-in-out infinite, shiny-rotate var(--shiny-duration) linear infinite;
  }

  /* Dot pattern overlay */
  .hero-cta::before {
    content: "";
    pointer-events: none;
    position: absolute;
    inset: 0;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
    width: calc(100% - var(--shiny-shadow-size) * 3);
    height: calc(100% - var(--shiny-shadow-size) * 3);
    background: radial-gradient(
      circle at 2px 2px,
      white calc(2px / 4),
      transparent 0
    ) padding-box;
    background-size: 4px 4px;
    background-repeat: space;
    mask-image: conic-gradient(
      from calc(var(--gradient-angle) + 45deg),
      black,
      transparent 10% 90%,
      black
    );
    border-radius: inherit;
    opacity: 0.3;
    z-index: -1;
    animation: shiny-rotate var(--shiny-duration) linear infinite;
  }

  /* Inner shimmer glow */
  .hero-cta::after {
    content: "";
    pointer-events: none;
    position: absolute;
    left: 50%;
    top: 50%;
    translate: -50% -50%;
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(
      -50deg,
      transparent,
      var(--shiny-highlight),
      transparent
    );
    mask-image: radial-gradient(circle at bottom, transparent 40%, black);
    opacity: 0.5;
    z-index: -1;
    animation: shiny-shimmer calc(var(--shiny-duration) * 1.5) linear infinite;
  }

  .hero-cta:active {
    translate: 0 1px;
  }

  /* Hover state: gradient expands and shifts */
  .hero-cta:hover,
  .hero-cta:focus-visible {
    --gradient-percent: 20%;
    --gradient-angle-offset: 95deg;
    --gradient-shine: var(--shiny-highlight-subtle);
    animation: shiny-rotate var(--shiny-duration) linear infinite;
    box-shadow: inset 0 0 0 1px var(--shiny-bg-subtle), 0 0 30px rgba(95, 75, 139, 0.4), 0 0 80px rgba(95, 75, 139, 0.15);
  }

  .hero-cta:hover::before,
  .hero-cta:focus-visible::before {
    opacity: 0.5;
  }

  @keyframes shiny-rotate {
    to {
      --gradient-angle: 360deg;
    }
  }

  @keyframes shiny-shimmer {
    to {
      rotate: 360deg;
    }
  }

  /* Subtle "breathing" glow so the eye catches the button at rest */
  @keyframes cta-pulse {
    0%, 100% { box-shadow: inset 0 0 0 1px var(--shiny-bg-subtle), 0 0 20px rgba(95, 75, 139, 0.25), 0 0 60px rgba(95, 75, 139, 0.1); }
    50% { box-shadow: inset 0 0 0 1px var(--shiny-bg-subtle), 0 0 28px rgba(95, 75, 139, 0.35), 0 0 80px rgba(95, 75, 139, 0.15); }
  }

  .hero-subline {
    font-family: 'Inter Variable', sans-serif;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
    margin-top: 1rem;
    text-align: center;
  }

  /* ---- Scroll indicator ---- */
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .scroll-mouse {
    width: 22px;
    height: 34px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    border-radius: 11px;
    position: relative;
    display: flex;
    justify-content: center;
  }
  .scroll-dot {
    width: 3px;
    height: 6px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 2px;
    margin-top: 6px;
    animation: scroll-bounce 2s ease-in-out infinite;
  }
  @keyframes scroll-bounce {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50% { transform: translateY(8px); opacity: 0.2; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-dot { animation: none; }
  }
</style>

<script>
  const scrollIndicator = document.querySelector('.scroll-indicator') as HTMLElement | null;
  if (scrollIndicator) {
    const updateIndicator = () => {
      scrollIndicator.style.opacity = window.scrollY > 100 ? '0' : '0.5';
    };
    updateIndicator();
    window.addEventListener('scroll', updateIndicator, { passive: true });
  }
</script>
