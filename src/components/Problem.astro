---
---
<section id="problem" class="problem-section" data-scroll-bg="problem">
  <!-- Decorative background layers (CSS only), must precede .problem-inner -->
  <div class="problem-hero-glow"></div>
  <div class="problem-top-fade"></div>
  <div class="aurora-wrap">
    <div class="aurora-layer"></div>
  </div>
  <div class="problem-dots"></div>

  <div class="problem-inner">
    <div class="problem-header">
      <span class="eyebrow">WHAT WE FIND</span>
      <h2>Most clinics are invisible<br/>where patients now ask.</h2>
    </div>

    <div class="problem-grid">
      <!-- LEFT: Scorecard (markup copied verbatim from the old Reveal section) -->
      <div class="problem-card">
        <div class="scorecard">
          <!-- Header -->
          <div class="scorecard-header">
            <span class="scorecard-label">AI VISIBILITY SCORECARD</span>
            <span class="scorecard-dot"></span>
          </div>
          <div class="scorecard-divider"></div>

          <!-- Score area: business name left, circular score right -->
          <div class="scorecard-score-area">
            <div class="scorecard-business">
              <span class="scorecard-name">Aster Aesthetics</span>
              <span class="scorecard-location">London, UK</span>
            </div>
            <div class="score-ring">
              <svg class="score-ring-svg" viewBox="0 0 120 120">
                <!-- Background circle -->
                <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="8"/>
                <!-- Score arc: 72% of full circle. Stroke-dasharray = 2*pi*52 = 326.7. 72% = 235.2 -->
                <circle cx="60" cy="60" r="52" fill="none" stroke="url(#scoreGradient)" stroke-width="8" stroke-linecap="round" stroke-dasharray="235.2 326.7" transform="rotate(-90 60 60)" class="score-arc"/>
                <!-- Gradient definition -->
                <defs>
                  <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#F59E0B"/>
                    <stop offset="100%" stop-color="#EF4444"/>
                  </linearGradient>
                </defs>
              </svg>
              <div class="score-number">
                <span class="score-value">72</span>
                <span class="score-total">/100</span>
              </div>
            </div>
          </div>

          <div class="scorecard-divider"></div>

          <!-- Channel rows -->
          <div class="scorecard-channels">
            <div class="channel-row">
              <span class="channel-name">Google Business Profile</span>
              <span class="channel-pill pill-strong">STRONG</span>
            </div>
            <div class="channel-row">
              <span class="channel-name">Local SEO</span>
              <span class="channel-pill pill-improving">IMPROVING</span>
            </div>
            <div class="channel-row channel-row-warn">
              <span class="channel-name">ChatGPT</span>
              <span class="channel-pill pill-at-risk">AT RISK</span>
            </div>
            <div class="channel-row channel-row-danger">
              <span class="channel-name">Perplexity</span>
              <span class="channel-pill pill-not-found">NOT FOUND</span>
            </div>
            <div class="channel-row">
              <span class="channel-name">Google AI Overviews</span>
              <span class="channel-pill pill-improving">IMPROVING</span>
            </div>
          </div>

          <!-- Footer -->
          <div class="scorecard-footer">
            <span class="scorecard-date">AUDITED 19 JUN 2026</span>
          </div>

          <!-- CTA inside card -->
          <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=scorecard" class="scorecard-cta">
            Get your free score →
          </a>
        </div>
      </div>

      <!-- RIGHT: Stats -->
      <div class="problem-stats">
        <div class="stat-item fade-up">
          <span class="stat-number" data-target="58">0<span class="stat-percent">%</span></span>
          <p class="stat-text">lower click-through for the top Google result when an AI Overview appears</p>
          <span class="stat-source">AHREFS, 2025</span>
        </div>
        <div class="stat-item fade-up">
          <span class="stat-number" data-target="8">0<span class="stat-percent">%</span></span>
          <p class="stat-text">of searches with an AI summary end in a click, versus 15% without</p>
          <span class="stat-source">PEW RESEARCH, 2025</span>
        </div>
      </div>
    </div>

    <p class="problem-tagline">This is what your scorecard looks like. Yours is free.</p>
  </div>
</section>

<style>
  /* ---- Merged section: solid dark base + CSS-only texture layers ---- */
  .problem-section {
    background: #1a1a24;
    position: relative;
    overflow: hidden;
    padding: 2rem 1.5rem 5rem;
  }

  /* Warm glow at the top edge, bleeding into the hero overlap zone */
  .problem-hero-glow {
    position: absolute;
    top: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 500px;
    background: radial-gradient(ellipse 100% 100% at 50% 0%, rgba(200, 180, 140, 0.22) 0%, transparent 60%);
    z-index: 0;
    pointer-events: none;
  }

  /* Aurora: slowly drifting plum light effect */
  .aurora-wrap {
    position: absolute;
    inset: -10px;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .aurora-layer {
    position: absolute;
    inset: -10px;
    opacity: 0.35;
    will-change: transform;
    filter: blur(12px);
    background-image:
      repeating-linear-gradient(
        100deg,
        #1a1a24 0%,
        #1a1a24 7%,
        transparent 10%,
        transparent 12%,
        #1a1a24 16%
      ),
      repeating-linear-gradient(
        100deg,
        #5F4B8B 10%,
        #7C6BAF 15%,
        #4A3A6E 20%,
        #8B7FD4 25%,
        #5F4B8B 30%
      );
    background-size: 300% 200%;
    background-position: 50% 50%;
    animation: aurora-drift 60s linear infinite;
    mask-image: radial-gradient(ellipse at 80% 20%, black 10%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at 80% 20%, black 10%, transparent 70%);
  }
  .aurora-layer::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        100deg,
        #1a1a24 0%,
        #1a1a24 7%,
        transparent 10%,
        transparent 12%,
        #1a1a24 16%
      ),
      repeating-linear-gradient(
        100deg,
        #5F4B8B 10%,
        #7C6BAF 15%,
        #4A3A6E 20%,
        #8B7FD4 25%,
        #5F4B8B 30%
      );
    background-size: 200% 100%;
    background-attachment: fixed;
    mix-blend-mode: difference;
    animation: aurora-drift 60s linear infinite;
  }

  @keyframes aurora-drift {
    from { background-position: 50% 50%, 50% 50%; }
    to { background-position: 350% 50%, 350% 50%; }
  }

  /* Decorative layer: subtle masked dot grid */
  .problem-dots {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(rgba(255, 255, 255, 0.08) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 75%);
  }

  /* Top gradient to smooth the hero-to-problem transition */
  .problem-top-fade {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 150px;
    background: linear-gradient(to bottom, rgba(20, 20, 32, 0.95) 0%, transparent 100%);
    z-index: 0;
    pointer-events: none;
  }

  /* Gradient fade from the dark section into the light services section below */
  .problem-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent 0%, #FAFAFA 100%);
    pointer-events: none;
    z-index: 2;
  }

  .problem-inner {
    max-width: 1140px;
    margin: 0 auto;
    position: relative;
    z-index: 3;
  }

  .problem-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .problem-header .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
  }

  .problem-header h2 {
    font-family: 'Fraunces Variable', serif;
    font-weight: 400;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    color: white;
    line-height: 1.2;
    margin-top: 1rem;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .problem-card {
    display: flex;
    justify-content: center;
  }

  /* ---- Stats column (frosted glass container) ---- */
  .problem-stats {
    background: rgba(30, 28, 45, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(95, 75, 139, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Thin divider between stat items (not after the last one) */
  .stat-item + .stat-item {
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .stat-number {
    font-family: 'Inter Variable', sans-serif;
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 700;
    color: #F0EEFF;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-percent {
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
  }

  .stat-text {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.5;
    max-width: 320px;
  }

  .stat-source {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
    margin-top: 0.15rem;
  }

  .problem-tagline {
    text-align: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.45);
    margin-top: 3rem;
    position: relative;
    z-index: 3;
  }

  /* ---- fade-up reveal for stat items (staggered) ---- */
  .fade-up {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1), transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .problem-section.is-visible .fade-up { opacity: 1; transform: translateY(0); }
  .problem-section.is-visible .stat-item:nth-child(1) { transition-delay: 0.05s; }
  .problem-section.is-visible .stat-item:nth-child(2) { transition-delay: 0.15s; }

  /* ============================================================
     Scorecard card — copied verbatim from the old Reveal section.
     No modifications to the card's own styles.
     ============================================================ */
  .scorecard {
    max-width: 480px;
    margin: 0 auto;
    background: rgba(30, 28, 45, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.2), 0 0 0 1px rgba(95, 75, 139, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .scorecard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .scorecard-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  .scorecard-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #5F4B8B;
    box-shadow: 0 0 8px rgba(95, 75, 139, 0.5);
  }

  .scorecard-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 1.25rem 0;
  }

  .scorecard-score-area {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .scorecard-business {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .scorecard-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: white;
  }

  .scorecard-location {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.4);
  }

  /* Circular progress ring */
  .score-ring {
    position: relative;
    width: 100px;
    height: 100px;
    flex-shrink: 0;
  }

  .score-ring-svg {
    width: 100%;
    height: 100%;
  }

  .score-arc {
    transition: stroke-dasharray 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .score-number {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .score-value {
    font-family: 'Inter Variable', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: white;
    line-height: 1;
  }

  .score-total {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.35);
    margin-left: 3px;
  }

  /* Channel rows */
  .scorecard-channels {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .channel-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 0.5rem;
    border-radius: 8px;
    transition: background 0.3s;
  }

  .channel-row-warn {
    background: rgba(245, 158, 11, 0.06);
  }

  .channel-row-danger {
    background: rgba(239, 68, 68, 0.08);
  }

  .channel-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  /* Status pills with real colors */
  .channel-pill {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 20px;
    border: 1px solid transparent;
  }

  .pill-strong {
    color: #22C55E;
    background: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
  }

  .pill-improving {
    color: #60A5FA;
    background: rgba(96, 165, 250, 0.1);
    border-color: rgba(96, 165, 250, 0.2);
  }

  .pill-at-risk {
    color: #F59E0B;
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.25);
  }

  .pill-not-found {
    color: #EF4444;
    background: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.25);
  }

  .scorecard-footer {
    margin-top: 1.25rem;
    text-align: center;
  }

  .scorecard-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .scorecard-cta {
    display: block;
    text-align: center;
    margin-top: 1rem;
    padding: 0.65rem 1.5rem;
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: white;
    background: rgba(95, 75, 139, 0.2);
    border: 1px solid rgba(95, 75, 139, 0.3);
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scorecard-cta:hover {
    background: rgba(95, 75, 139, 0.35);
    border-color: rgba(95, 75, 139, 0.5);
    transform: translateY(-1px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .problem-stats {
      gap: 0;
    }
    .stat-item {
      text-align: center;
      align-items: center;
    }
    .stat-text {
      max-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .score-arc { transition: none; }
    .scorecard-cta { transition: color 0.3s, background 0.3s; }
    .fade-up { opacity: 1; transform: none; transition: none; }
    .aurora-layer,
    .aurora-layer::after { animation: none; }
  }
</style>

<script>
  (function() {
    const section = document.querySelector('#problem');
    if (!section) return;

    const arc = section.querySelector('.score-arc') as SVGElement | null;
    const counters = section.querySelectorAll<HTMLElement>('.stat-number[data-target]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Reset the score ring to empty so it can draw in on reveal.
    if (arc && !reduceMotion) arc.style.strokeDasharray = '0 326.7';

    function countUp(el: HTMLElement) {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      const valueNode = el.firstChild; // the leading text node, before <span class="stat-percent">
      if (reduceMotion) {
        if (valueNode) valueNode.nodeValue = String(target);
        return;
      }
      const duration = 1500;
      let start: number | null = null;
      function frame(ts: number) {
        if (start === null) start = ts;
        const p = Math.min((ts - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3); // ease-out cubic
        if (valueNode) valueNode.nodeValue = String(Math.round(eased * target));
        if (p < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
          // Score ring draws in at the same time as the stats count up.
          if (arc && !reduceMotion) arc.style.strokeDasharray = '235.2 326.7';
          counters.forEach(countUp);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });

    observer.observe(section);
  })();
</script>
