---
---
<nav id="main-nav" class="nav nav-dark">
  <div class="nav-inner container">
    <a href="/" class="nav-logo">prefera</a>
    <div class="nav-links">
      <a href="/#services" class="rot-link"><span class="rot"><span class="rot-front">Services</span><span class="rot-back">Services</span></span></a>
      <a href="/#approach" class="rot-link"><span class="rot"><span class="rot-front">Approach</span><span class="rot-back">Approach</span></span></a>
      <a href="/#faq" class="rot-link"><span class="rot"><span class="rot-front">FAQ</span><span class="rot-back">FAQ</span></span></a>
      <a href="/about/" class="rot-link"><span class="rot"><span class="rot-front">About</span><span class="rot-back">About</span></span></a>
    </div>
    <div class="nav-burger-container">
      <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span class="nav-burger-bar"></span>
        <span class="nav-burger-bar"></span>
        <span class="nav-burger-bar"></span>
      </button>
    </div>
    <div id="mobile-menu" class="mobile-menu" hidden>
      <a href="/#services" class="mobile-menu-link">Services</a>
      <a href="/#approach" class="mobile-menu-link">Approach</a>
      <a href="/#faq" class="mobile-menu-link">FAQ</a>
      <a href="/about/" class="mobile-menu-link">About</a>
    </div>
    <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=nav" class="nav-cta rot-link"><span class="rot"><span class="rot-front">Book a free audit</span><span class="rot-back">Book a free audit</span></span></a>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const darkBgKeys = ['hero', 'reveal', 'stats', 'cta', 'footer'];
  const sections = document.querySelectorAll('[data-scroll-bg]');

  const navObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bgKey = entry.target.getAttribute('data-scroll-bg');
        if (darkBgKeys.includes(bgKey)) {
          nav.classList.add('nav-dark');
          nav.classList.remove('nav-light');
        } else {
          nav.classList.add('nav-light');
          nav.classList.remove('nav-dark');
        }
      }
    });
  }, {
    threshold: 0,
    rootMargin: '-10% 0px -85% 0px'
  });

  sections.forEach(section => navObserver.observe(section));

  // Initial state: dark only over the homepage hero. Standalone pages
  // (about, services, privacy, terms) open on light content, and their
  // dark footer sections are handled by the observer once scrolled to.
  if (document.querySelector('.hero')) {
    nav.classList.add('nav-dark');
  } else {
    nav.classList.remove('nav-dark');
    nav.classList.add('nav-light');
  }

  // Mobile menu toggle
  const burger = document.querySelector('.nav-burger');
  const mobileMenu = document.getElementById('mobile-menu');
  if (burger && mobileMenu) {
    burger.addEventListener('click', () => {
      const isOpen = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', !isOpen);
      mobileMenu.hidden = isOpen;
    });

    // Close menu when a link is clicked
    const links = mobileMenu.querySelectorAll('.mobile-menu-link');
    links.forEach(link => {
      link.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        mobileMenu.hidden = true;
      });
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    transition: background 400ms ease, border-color 400ms ease;
  }
  .nav-light a, .nav-light .nav-logo { transition: color 400ms ease; }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 2rem;
  }
  .nav-logo {
    font-family: var(--font-sans);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 0.5rem;
    margin-left: auto;
    margin-right: 1.5rem;
  }
  .nav-links a {
    position: relative;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 100px;
    transition: color 200ms ease;
  }
  /* button-shape that fades + scales in on hover */
  .nav-links a::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 300ms ease, transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-links a:hover::before { opacity: 1; transform: scale(1); }
  .nav.nav-dark .nav-links a::before { background: rgba(255,255,255,0.12); }
  .nav.nav-light .nav-links a::before { background: var(--accent-soft); }
  .nav-cta {
    display: inline-block;
    border-radius: 50px;
    padding: 0.625rem 1.25rem;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-decoration: none;
    overflow: hidden;
    transition: background 300ms ease, border-color 300ms ease, color 300ms ease, box-shadow 300ms ease;
  }
  /* Dark/transparent mode (over hero): glass feel */
  .nav.nav-dark .nav-cta {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
  }
  .nav.nav-dark .nav-cta:hover {
    background: rgba(255,255,255,0.18);
    border-color: rgba(255,255,255,0.35);
  }

  /* Smooth vertical roll on hover (links + CTA) — label slides up and out
     while an identical copy rolls up into place. No rotation, no shake. */
  .rot {
    position: relative;
    display: inline-block;
    overflow: hidden;
    line-height: 1.25;
    vertical-align: bottom;
  }
  .rot-front, .rot-back {
    display: block;
    transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .rot-back {
    position: absolute;
    left: 0;
    top: 0;
    transform: translateY(100%);
  }
  .rot-link:hover .rot-front { transform: translateY(-100%); }
  .rot-link:hover .rot-back { transform: translateY(0); }
  @media (prefers-reduced-motion: reduce) {
    .rot-front, .rot-back { transition: none; }
    .rot-back { transform: translateY(100%); }
  }

  /* Dark state (over hero) */
  .nav.nav-dark {
    background: transparent;
    border-bottom: 1px solid transparent;
  }
  .nav.nav-dark .nav-logo { color: #fff; }
  .nav.nav-dark .nav-links a { color: rgba(255,255,255,0.7); }
  .nav.nav-dark .nav-links a:hover { color: #fff; }

  /* Light state (scrolled past hero) */
  .nav.nav-light {
    background: rgba(250,250,250,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav.nav-light .nav-logo { color: var(--text-primary); }
  .nav.nav-light .nav-links a { color: var(--text-secondary); }
  .nav.nav-light .nav-links a:hover { color: var(--text-primary); }
  /* Light/solid mode (scrolled): solid plum pill */
  .nav.nav-light .nav-cta {
    background: #5F4B8B;
    border: 1px solid #5F4B8B;
    color: #fff;
    border-radius: 50px;
    box-shadow: 0 1px 2px rgba(95,75,139,0.15), 0 4px 16px rgba(95,75,139,0.2);
  }
  .nav.nav-light .nav-cta:hover {
    background: #4A3A6E;
    border-color: #4A3A6E;
  }

  /* Mobile hamburger button */
  .nav-burger-container {
    display: none;
    margin-left: auto;
  }
  .nav-burger {
    all: unset;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    cursor: pointer;
    background: none;
    border: none;
  }
  .nav.nav-dark .nav-burger { color: #fff; }
  .nav.nav-light .nav-burger { color: var(--text-primary); }
  .nav-burger-bar {
    display: block;
    width: 24px;
    height: 1.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 300ms ease, opacity 300ms ease;
  }
  .nav-burger-bar + .nav-burger-bar {
    margin-top: 5px;
  }
  .nav-burger[aria-expanded="true"] .nav-burger-bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .nav-burger-bar:nth-child(2) {
    opacity: 0;
  }
  .nav-burger[aria-expanded="true"] .nav-burger-bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* Mobile menu panel. Hidden by default: an explicit `display` would
     override the `hidden` attribute, so only the open state sets flex,
     and only at mobile widths (see the media query below). */
  .mobile-menu {
    display: none;
    position: absolute;
    top: 72px;
    left: 0;
    right: 0;
    width: 100%;
    background: rgba(12, 12, 14, 0.97);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    z-index: 99;
    flex-direction: column;
  }
  .mobile-menu-link {
    display: block;
    padding: 0.875rem 1.5rem;
    font-size: 1rem;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    color: white;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    transition: color 200ms ease, background 200ms ease;
  }
  .mobile-menu-link:last-child {
    border-bottom: none;
  }
  .mobile-menu-link:hover {
    background: rgba(255, 255, 255, 0.05);
  }
  .nav.nav-light .mobile-menu {
    background: rgba(250, 250, 250, 0.97);
    border-bottom-color: rgba(0, 0, 0, 0.08);
  }
  .nav.nav-light .mobile-menu-link {
    color: var(--text-primary);
    border-bottom-color: rgba(0, 0, 0, 0.04);
  }
  .nav.nav-light .mobile-menu-link:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-burger-container { display: flex; }
    .mobile-menu:not([hidden]) { display: flex; }
  }
</style>
