---
// Header copy, split into characters for the blurred-stagger reveal.
const eyebrowText = "WHAT WE DO";
const headingText = "Every layer of how customers find you. Handled.";
const subtext = "Search. Maps. AI answers. The phone ringing at 7 PM. Most agencies sell you one piece. We cover the full chain, because a gap anywhere means lost revenue everywhere.";
---
<section id="services" data-scroll-bg="services">
  <!-- Decorative lavender glow (behind all content) -->
  <div class="services-glow" aria-hidden="true"></div>

  <!-- Section header: centered, not inside the sticky area -->
  <div class="services-header">
    <span class="eyebrow bs-text" style="--bs-base: 0s">
      {eyebrowText.split("").map((ch, i) => (
        <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
      ))}
    </span>
    <h2 class="bs-text" style="--bs-base: 0.18s">
      {headingText.split("").map((ch, i) => (
        <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
      ))}
    </h2>
    <p class="services-subtext bs-text" style="--bs-base: 0.55s">
      {subtext.split("").map((ch, i) => (
        <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
      ))}
    </p>
  </div>

  <!-- Scroll-driven container -->
  <div class="services-scroll-container">
    <div class="services-sticky">
      <!-- LEFT: nav labels + active copy + CTA -->
      <div class="services-left">
        <div class="services-nav">
          <button class="service-label active" data-index="0">Google Business Profile</button>
          <button class="service-label" data-index="1">Local SEO</button>
          <button class="service-label" data-index="2">AI search visibility</button>
          <button class="service-label" data-index="3">AI voice assistant</button>
          <button class="service-label" data-index="4">Website that works</button>
        </div>

        <div class="service-copy-container">
          <div class="service-copy active" data-copy="0">
            <h3 class="service-q">What is Google Business Profile management?</h3>
            <p class="pain">A customer searches for what you do, in your city. Your profile has no photos, outdated hours, and two reviews from 2022. They tap the next result. You never knew they were looking.</p>
            <p class="fix">We build and manage your Google Business Profile so it shows up complete, trusted, and first in the local map pack. Photos, posts, reviews, categories, all handled weekly.</p>
            <p class="stat"><span class="stat-num">84%</span> of profile views come from discovery searches, not direct. If your profile is weak, you lose before they know your name.</p>
          </div>
          <div class="service-copy" data-copy="1">
            <h3 class="service-q">What is local SEO?</h3>
            <p class="pain">You have a website. It looks fine. But search your service plus your city and you are on page three. Competitors with worse sites rank above you because they have the signals Google actually weighs.</p>
            <p class="fix">We wire your site with structured data, local citations, consistent NAP, review velocity, and city-level landing pages. The infrastructure that moves you from invisible to the top three.</p>
            <p class="stat"><span class="stat-num">46%</span> of all Google searches have local intent. If you do not rank for your city, nearly half of search traffic will never find you.</p>
          </div>
          <div class="service-copy" data-copy="2">
            <h3 class="service-q">How do you get cited by ChatGPT and Perplexity?</h3>
            <p class="pain">Someone asks ChatGPT for a recommendation in your area. It names three businesses. You are not one of them. That person never opens Google. They book wherever the AI pointed them.</p>
            <p class="fix">We structure your digital footprint so ChatGPT, Perplexity, and Google AI Overviews recognize your business and cite it by name. Schema, entity optimization, and content AI models can parse.</p>
            <p class="stat"><span class="stat-num">58%</span> fewer clicks to websites when a Google AI Overview appears. The traffic you used to get is now answered before anyone clicks.</p>
          </div>
          <div class="service-copy" data-copy="3">
            <h3 class="service-q">What does an AI voice assistant do?</h3>
            <p class="pain">A customer calls at 7 PM. You are with your last client. The phone rings out. They call the next name on the list. You lost that booking and you will never know it.</p>
            <p class="fix">Our AI answers every call, books appointments into your calendar, and speaks your customer's language. No hold music, no voicemail, no missed revenue.</p>
            <p class="stat"><span class="stat-num">62%</span> of callers who reach voicemail will not leave a message or call back. Every missed call is a customer your competitor gets for free.</p>
          </div>
          <div class="service-copy" data-copy="4">
            <h3 class="service-q">Why does a website need to be search-ready?</h3>
            <p class="pain">Your website looks fine to humans. But Google cannot read it. No structured data, no local schema, no city pages, slow mobile load. A beautiful site that search engines ignore is a brochure no one picks up.</p>
            <p class="fix">We build or rebuild your site so it performs where it counts: fast Core Web Vitals, proper schema markup, location pages that rank, and content structured for both search engines and AI crawlers.</p>
            <p class="stat"><span class="stat-num">53%</span> of mobile visitors leave a site that takes longer than 3 seconds to load. Speed is not a feature. It is the entry ticket.</p>
          </div>
        </div>

        <a href="/book" class="services-cta">Book a free audit →</a>
      </div>

      <!-- RIGHT: mock card only -->
      <div class="services-right">
        <!-- Panel 0: Google Maps pack -->
        <div class="service-panel active" data-panel="0">
          <div class="mock-card">
            <div class="gmap">
              <span class="gmap-road gmap-road-h1"></span>
              <span class="gmap-road gmap-road-h2"></span>
              <span class="gmap-road gmap-road-v1"></span>
              <span class="gmap-road gmap-road-v2"></span>
              <div class="gmap-pin">
                <span class="gmap-pin-head"></span>
                <span class="gmap-ping"></span>
              </div>
              <div class="gmap-attribution">Map data ©2026</div>
            </div>
            <div class="gmap-listings">
              <div class="gmap-listing highlighted">
                <div class="gmap-rank">1</div>
                <div class="gmap-info">
                  <div class="gmap-name">De Brug Fysiotherapie</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score">4.9</span>
                    <span class="gmap-stars">★★★★★</span>
                    <span class="gmap-reviews">(89)</span>
                  </div>
                  <div class="gmap-detail">Physiotherapist · Voorstraat 28</div>
                  <div class="gmap-status"><span class="gmap-dot"></span>Open · Closes 6 PM</div>
                </div>
              </div>
              <div class="gmap-listing dim">
                <div class="gmap-rank">2</div>
                <div class="gmap-info">
                  <div class="gmap-name">Utrecht Fysio Centrum</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score-dim">4.2</span>
                    <span class="gmap-stars-dim">★★★★☆</span>
                    <span class="gmap-reviews-dim">(34)</span>
                  </div>
                  <div class="gmap-detail-dim">Physiotherapist · Lange Viestraat 5</div>
                </div>
              </div>
              <div class="gmap-listing more-dim">
                <div class="gmap-rank">3</div>
                <div class="gmap-info">
                  <div class="gmap-name">FysioFit Utrecht</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score-dim">3.8</span>
                    <span class="gmap-stars-dim">★★★★</span>
                    <span class="gmap-reviews-dim">(12)</span>
                  </div>
                  <div class="gmap-detail-dim">Physiotherapist · Catharijnesingel 90</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 1: Google Search results -->
        <div class="service-panel" data-panel="1">
          <div class="mock-card">
            <div class="serp-top">
              <div class="serp-searchbar">
                <svg class="serp-search-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="7" stroke="#9ca3af" stroke-width="2"/>
                  <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="serp-query">fysiotherapie utrecht</span>
              </div>
              <div class="serp-stats">About 892,000 results (0.43 seconds)</div>
            </div>
            <div class="serp-results">
              <div class="serp-result serp-result-top">
                <span class="serp-rank">#1</span>
                <div class="serp-url-line">
                  <span class="serp-favicon"></span>
                  <span class="serp-url">debrugfysio.nl<span class="serp-url-path"> › fysiotherapie</span></span>
                </div>
                <div class="serp-title">De Brug Fysiotherapie — Utrecht's Top Practice</div>
                <div class="serp-desc">Experienced physiotherapy in Utrecht centrum. Book online for sports rehab, manual therapy, and chronic pain treatment. Open Monday through Friday.</div>
              </div>
              <div class="serp-result serp-result-2">
                <div class="serp-url-line">
                  <span class="serp-favicon dim"></span>
                  <span class="serp-url dim">utrechtfysiocentrum.nl</span>
                </div>
                <div class="serp-title">Utrecht Fysio Centrum</div>
                <div class="serp-desc">Fysiotherapie in Utrecht voor klachten aan rug, nek en schouders...</div>
              </div>
              <div class="serp-result serp-result-3">
                <div class="serp-url-line">
                  <span class="serp-favicon dim"></span>
                  <span class="serp-url">fysiofit-utrecht.nl</span>
                </div>
                <div class="serp-title">FysioFit Utrecht</div>
                <div class="serp-desc">Sportfysiotherapie en revalidatie in Utrecht...</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 2: AI search response (ChatGPT) -->
        <div class="service-panel" data-panel="2">
          <div class="mock-card chatgpt-card">
            <div class="cg-label">AI SEARCH RESPONSE</div>
            <div class="cg-question">Can you recommend a good physiotherapist in Utrecht for a sports injury?</div>
            <div class="cg-response">
              <div class="cg-head">
                <span class="cg-avatar">AI</span>
                <span class="cg-name">ChatGPT</span>
              </div>
              <div class="cg-text">Based on reviews and location data, I'd recommend <strong>De Brug Fysiotherapie</strong> on Voorstraat in Utrecht centrum. They specialize in sports rehabilitation and have a 4.9 rating across 89 reviews. They offer online booking and accept most Dutch insurance providers.</div>
            </div>
            <div class="cg-sources">
              <span class="cg-sources-label">SOURCES</span>
              <span class="cg-source">debrugfysio.nl ↗</span>
              <span class="cg-source">google.com/maps ↗</span>
            </div>
          </div>
        </div>

        <!-- Panel 3: AI voice assistant -->
        <div class="service-panel" data-panel="3">
          <div class="mock-card voice-card">
            <div class="vc-header">
              <div class="vc-label">AI VOICE ASSISTANT</div>
              <div class="vc-active"><span class="vc-dot"></span>Active call · 0:34</div>
              <div class="vc-caller">+31 6 1234 5678</div>
            </div>
            <div class="vc-transcript">
              <div class="vc-msg">
                <div class="vc-msg-label">CUSTOMER</div>
                <div class="vc-msg-text">Hi, I need to book a session for my lower back, preferably Thursday</div>
              </div>
              <div class="vc-msg">
                <div class="vc-msg-label vc-ai">PREFERA AI</div>
                <div class="vc-msg-text">Of course! I have 9:00 and 15:30 available this Thursday. Which works better?</div>
              </div>
              <div class="vc-msg">
                <div class="vc-msg-label">CUSTOMER</div>
                <div class="vc-msg-text">9 works, thanks</div>
              </div>
            </div>
            <div class="vc-status">BOOKING CONFIRMED · SYNCED TO CALENDAR</div>
          </div>
        </div>

        <!-- Panel 4: Website performance dashboard (PageSpeed Insights) -->
        <div class="service-panel" data-panel="4">
          <div class="mock-card pagespeed-card">
            <div class="ps-label">PAGESPEED INSIGHTS</div>
            <div class="ps-url">
              <span class="ps-lock"></span>
              <span class="ps-url-text">debrugfysio.nl</span>
            </div>
            <div class="ps-scores">
              <div class="ps-score">
                <div class="ps-ring">
                  <svg viewBox="0 0 48 48" aria-hidden="true">
                    <circle cx="24" cy="24" r="20" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>
                    <circle cx="24" cy="24" r="20" fill="none" stroke="#22C55E" stroke-width="3" stroke-linecap="round" stroke-dasharray="121.8 125.6" transform="rotate(-90 24 24)"/>
                  </svg>
                  <span class="ps-score-num">97</span>
                </div>
                <span class="ps-score-label">Performance</span>
              </div>
              <div class="ps-score">
                <div class="ps-ring">
                  <svg viewBox="0 0 48 48" aria-hidden="true">
                    <circle cx="24" cy="24" r="20" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>
                    <circle cx="24" cy="24" r="20" fill="none" stroke="#22C55E" stroke-width="3" stroke-linecap="round" stroke-dasharray="125.6 125.6" transform="rotate(-90 24 24)"/>
                  </svg>
                  <span class="ps-score-num">100</span>
                </div>
                <span class="ps-score-label">Accessibility</span>
              </div>
              <div class="ps-score">
                <div class="ps-ring">
                  <svg viewBox="0 0 48 48" aria-hidden="true">
                    <circle cx="24" cy="24" r="20" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>
                    <circle cx="24" cy="24" r="20" fill="none" stroke="#22C55E" stroke-width="3" stroke-linecap="round" stroke-dasharray="119.3 125.6" transform="rotate(-90 24 24)"/>
                  </svg>
                  <span class="ps-score-num">95</span>
                </div>
                <span class="ps-score-label">Best Practices</span>
              </div>
              <div class="ps-score">
                <div class="ps-ring">
                  <svg viewBox="0 0 48 48" aria-hidden="true">
                    <circle cx="24" cy="24" r="20" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>
                    <circle cx="24" cy="24" r="20" fill="none" stroke="#22C55E" stroke-width="3" stroke-linecap="round" stroke-dasharray="125.6 125.6" transform="rotate(-90 24 24)"/>
                  </svg>
                  <span class="ps-score-num">100</span>
                </div>
                <span class="ps-score-label">SEO</span>
              </div>
            </div>
            <div class="ps-metrics">
              <div class="ps-metric">
                <span class="ps-metric-val">0.8s</span>
                <span class="ps-metric-label">LCP</span>
              </div>
              <div class="ps-metric">
                <span class="ps-metric-val">12ms</span>
                <span class="ps-metric-label">INP</span>
              </div>
              <div class="ps-metric">
                <span class="ps-metric-val">0.02</span>
                <span class="ps-metric-label">CLS</span>
              </div>
            </div>
            <div class="ps-schema">
              <div class="ps-schema-line"><span class="ps-check">✓</span>LocalBusiness schema detected</div>
              <div class="ps-schema-line"><span class="ps-check">✓</span>6 structured data types found</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #services {
    position: relative;
    z-index: 1;
    background: transparent;
    /* NOTE: no `overflow: hidden` here — it would break the sticky-tabs
       (position: sticky needs no clipping ancestor). The glow below is
       inset:0, so it stays within the section bounds without clipping. */
  }

  /* Decorative lavender-plum glow: very subtle, sits behind all content.
     inset:0 so it stays within the section bounds; invisible on dark body. */
  .services-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(ellipse 90% 60% at 50% 35%, rgba(196, 181, 253, 0.35) 0%, rgba(95, 75, 139, 0.12) 45%, transparent 75%);
  }

  /* ---- Header ---- */
  .services-header {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 6rem 1.5rem 3rem;
  }
  .services-header .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #5F4B8B;
  }
  .services-header h2 {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.15;
    color: #1a1a1f;
    margin-top: 1rem;
  }
  .services-subtext {
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    color: #6b7280;
    line-height: 1.7;
    margin-top: 1rem;
  }

  /* ---- Blurred-stagger reveal: per-letter blur(10px)->0 + fade, staggered ---- */
  .bs-char {
    opacity: 0;
    filter: blur(10px);
  }
  .services-header.is-visible .bs-char {
    animation: bs-blur-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--bs-base, 0s) + var(--bs-i) * 0.015s);
  }
  @keyframes bs-blur-in {
    to {
      opacity: 1;
      filter: blur(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .bs-char { opacity: 1; filter: none; animation: none; }
  }

  /* ---- Scroll-driven container ---- */
  .services-scroll-container {
    position: relative;
    z-index: 1;
    height: 375vh;
  }
  .services-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Left: nav labels + active copy + CTA ---- */
  .services-left {
    width: 42%;
    display: flex;
    flex-direction: column;
  }
  .services-nav {
    margin-bottom: 1.5rem;
  }
  .service-label {
    all: unset;
    cursor: pointer;
    display: block;
    width: 100%;
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.2;
    padding: 0.85rem 0;
    color: #6b7280;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1), padding-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: left;
  }
  .service-label:first-child {
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .service-label.active {
    color: #1a1a1f;
    padding-left: 6px;
  }
  .service-label.active::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 1em;
    background: #5F4B8B;
    border-radius: 2px;
    margin-right: 10px;
    vertical-align: middle;
  }
  .service-label:hover:not(.active) {
    color: #374151;
  }

  /* Copies share a single grid cell so the container auto-sizes to the
     tallest copy (no absolute overflow), keeping the CTA clear of the text. */
  .service-copy-container {
    display: grid;
    margin-bottom: 1.5rem;
  }
  .service-copy {
    grid-area: 1 / 1;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    visibility: hidden;
    padding-top: 1.25rem;
  }
  .service-copy.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }
  .service-q {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: 1.1rem;
    color: #1a1a1f;
    line-height: 1.25;
    margin: 0 0 0.85rem;
  }
  .pain {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .fix {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: #1a1a1f;
    font-weight: 500;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .stat {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: #6b7280;
    font-style: italic;
    line-height: 1.6;
  }
  .stat-num {
    color: #5F4B8B;
    font-weight: 600;
    font-style: normal;
  }

  .services-cta {
    display: inline-block;
    align-self: flex-start;
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #5F4B8B;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.3s;
  }
  .services-cta:hover { opacity: 0.7; }

  /* ---- Right: mock card panels ---- */
  .services-right {
    width: 53%;
    position: relative;
    min-height: 500px;
  }
  .service-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    visibility: hidden;
  }
  .service-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  /* ---- Mock card (shared) ---- */
  .mock-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  @media (hover: hover) {
    .mock-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.06);
    }
  }

  /* ---- Card 0: Google Maps pack ---- */
  .gmap {
    position: relative;
    height: 180px;
    background: #E8F5E9;
    overflow: hidden;
  }
  .gmap-road {
    position: absolute;
    background: rgba(255,255,255,0.7);
  }
  .gmap-road-h1 { left: 0; right: 0; top: 30%; height: 3px; }
  .gmap-road-h2 { left: 0; right: 0; top: 65%; height: 3px; }
  .gmap-road-v1 { top: 0; bottom: 0; left: 30%; width: 3px; }
  .gmap-road-v2 { top: 0; bottom: 0; left: 65%; width: 3px; }
  .gmap-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 30px;
    transform: translate(-50%, -100%);
  }
  .gmap-pin-head {
    position: absolute;
    top: 0;
    left: 50%;
    width: 22px;
    height: 22px;
    margin-left: -11px;
    background: #EA4335;
    border-radius: 50% 50% 50% 0;
    transform: rotate(45deg);
    box-shadow: 0 2px 8px rgba(234,67,53,0.4);
  }
