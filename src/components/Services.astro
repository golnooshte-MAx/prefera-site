<script>
  (function() {
    const container = document.querySelector('.services-scroll-container');
    const labels = document.querySelectorAll('.service-label');
    const panels = document.querySelectorAll('.service-panel');
    const copies = document.querySelectorAll('.service-copy');
    if (!container || !labels.length || !panels.length) return;

    let currentIndex = 0;
    let isClickScrolling = false;
    const isMobile = () => window.innerWidth < 768;

    function setActive(index) {
      if (index === currentIndex && labels[index].classList.contains('active')) return;
      currentIndex = index;
      labels.forEach((l, i) => l.classList.toggle('active', i === index));
      panels.forEach((p, i) => p.classList.toggle('active', i === index));
      copies.forEach((c, i) => c.classList.toggle('active', i === index));
    }

    // Click: immediately show the panel (crossfade), then scroll the page so the
    // scroll-driven tracker stays in sync. isClickScrolling stops onScroll from
    // overriding the selection mid-animation.
    labels.forEach(label => {
      label.addEventListener('click', () => {
        const index = parseInt(label.dataset.index);
        setActive(index);
        if (isMobile()) return;

        isClickScrolling = true;
        // Absolute document position of the container top (offsetTop is relative
        // to #services, its positioned offset parent, so it can't be used here).
        const containerTop = container.getBoundingClientRect().top + window.scrollY;
        const scrollableHeight = container.offsetHeight - window.innerHeight;
        const numServices = labels.length;
        const targetScroll = containerTop + (scrollableHeight * index / (numServices - 1));
        window.scrollTo({ top: targetScroll, behavior: 'smooth' });

        setTimeout(() => { isClickScrolling = false; }, 1000);
      });
    });

    function onScroll() {
      if (isMobile() || isClickScrolling) return;
      const rect = container.getBoundingClientRect();
      const scrollableHeight = container.offsetHeight - window.innerHeight;
      const scrolled = -rect.top / scrollableHeight;
      const progress = Math.max(0, Math.min(0.999, scrolled));
      const numServices = labels.length;
      const newIndex = Math.min(numServices - 1, Math.floor(progress * numServices));
      setActive(newIndex);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    setActive(0);
  })();
</script>

<script>
  // Trigger the blurred-stagger header reveal once it scrolls into view.
  (function() {
    const header = document.querySelector('#services .services-header');
    if (!header) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(header);
  })();
</script>
