---
// Header copy, split into characters for the blurred-stagger reveal.
const eyebrowText = "WHAT WE DO";
const headingText = "Every way patients find a clinic. Handled.";
const subtext = "Search. Maps. AI answers. Most agencies sell you one piece. We cover the full chain, because a gap anywhere means lost patients everywhere.";
---
<section id="services" data-scroll-bg="services">
  <!-- Decorative lavender glow (behind all content) -->
  <div class="services-glow" aria-hidden="true"></div>

  <!-- Section header: centered, not inside the sticky area -->
  <div class="services-header">
    <span class="eyebrow bs-text" style="--bs-base: 0s">
      <span class="sr-only">{eyebrowText}</span>
      <span aria-hidden="true">
        {eyebrowText.split("").map((ch, i) => (
          <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
        ))}
      </span>
    </span>
    <h2 class="bs-text" style="--bs-base: 0.18s">
      <span class="sr-only">{headingText}</span>
      <span aria-hidden="true">
        {headingText.split("").map((ch, i) => (
          <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
        ))}
      </span>
    </h2>
    <p class="services-subtext bs-text" style="--bs-base: 0.55s">
      <span class="sr-only">{subtext}</span>
      <span aria-hidden="true">
        {subtext.split("").map((ch, i) => (
          <span class="bs-char" style={`--bs-i:${i}`}>{ch}</span>
        ))}
      </span>
    </p>
  </div>

  <!-- Scroll-driven container -->
  <div class="services-scroll-container">
    <div class="services-sticky">
      <!-- LEFT: nav labels + active copy + CTA -->
      <div class="services-left">
        <div class="services-nav">
          <button class="service-label active" data-index="0">What is AEO</button>
          <button class="service-label" data-index="1">Getting recommended</button>
          <button class="service-label" data-index="2">AI visibility vs SEO</button>
          <button class="service-label" data-index="3">Tracking and reporting</button>
        </div>

        <div class="service-copy-container">
          <div class="service-copy active" data-copy="0">
            <h3 class="service-q">What is AEO for aesthetic clinics?</h3>
            <p class="pain">A prospective patient asks ChatGPT for the best clinic for lip filler in your city. It names two or three clinics. You are not one of them. That patient never opens Google. They book wherever the AI pointed them.</p>
            <p class="fix">AEO (answer engine optimization) is the work of making your clinic the answer AI assistants give. We make your clinic visible in the sources those assistants actually draw from.</p>
          </div>
          <div class="service-copy" data-copy="1">
            <h3 class="service-q">How do clinics get recommended by ChatGPT?</h3>
            <p class="pain">AI assistants recommend clinics they keep encountering in sources they trust. If your clinic only exists on your own website, there is nothing for them to find.</p>
            <p class="fix">We build your off-site authority: local press, professional directories, review platforms, and community discussions. Not schema tricks: real mentions in the places AI models actually read. First citations typically appear in 6 to 9 weeks.</p>
          </div>
          <div class="service-copy" data-copy="2">
            <h3 class="service-q">AI visibility vs SEO for clinics</h3>
            <p class="pain">SEO gets you ranked in a list of links. AI visibility gets you named in the answer itself. Ranking first matters less when an AI answer sits on top of the results.</p>
            <p class="fix">You still need both, and we cover both. The clinics that win are cited in the answer, not just ranked under it.</p>
            <p class="stat"><span class="stat-num">58%</span> fewer clicks for the top Google result when an AI Overview appears (Ahrefs, 2025).</p>
          </div>
          <div class="service-copy" data-copy="3">
            <h3 class="service-q">What do you track and report?</h3>
            <p class="pain">Most agencies send a dashboard you never open, full of numbers that do not mean anything. You should know exactly where you appear and where you do not.</p>
            <p class="fix">We track citations across ChatGPT, Perplexity, Google AI Overviews, and Claude for the queries your patients actually ask. A monthly visibility score, the exact prompts, and the actions taken. No black-box dashboards.</p>
          </div>
        </div>

        <a href="https://prefera.dev/book/?utm_source=website&utm_medium=cta&utm_campaign=services" class="services-cta">Book a free audit →</a>
      </div>

      <!-- RIGHT: mock card only -->
      <div class="services-right">
        <!-- Panel 0: Google Maps pack -->
        <div class="service-panel" data-panel="2">
          <div class="mock-card">
            <div class="gmap">
              <span class="gmap-road gmap-road-h1"></span>
              <span class="gmap-road gmap-road-h2"></span>
              <span class="gmap-road gmap-road-v1"></span>
              <span class="gmap-road gmap-road-v2"></span>
              <div class="gmap-pin">
                <span class="gmap-pin-head"></span>
                <span class="gmap-ping"></span>
              </div>
              <div class="gmap-attribution">Map data ©2026</div>
            </div>
            <div class="gmap-listings">
              <div class="gmap-listing highlighted">
                <div class="gmap-rank">1</div>
                <div class="gmap-info">
                  <div class="gmap-name">Aster Aesthetics</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score">4.9</span>
                    <span class="gmap-stars">★★★★★</span>
                    <span class="gmap-reviews">(89)</span>
                  </div>
                  <div class="gmap-detail">Aesthetic clinic · Marylebone High St</div>
                  <div class="gmap-status"><span class="gmap-dot"></span>Open · Closes 6 PM</div>
                </div>
              </div>
              <div class="gmap-listing dim">
                <div class="gmap-rank">2</div>
                <div class="gmap-info">
                  <div class="gmap-name">Glow Aesthetics</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score-dim">4.2</span>
                    <span class="gmap-stars-dim">★★★★☆</span>
                    <span class="gmap-reviews-dim">(34)</span>
                  </div>
                  <div class="gmap-detail-dim">Aesthetic clinic · Kings Road</div>
                </div>
              </div>
              <div class="gmap-listing more-dim">
                <div class="gmap-rank">3</div>
                <div class="gmap-info">
                  <div class="gmap-name">The Skin Studio</div>
                  <div class="gmap-rating-line">
                    <span class="gmap-score-dim">3.8</span>
                    <span class="gmap-stars-dim">★★★★</span>
                    <span class="gmap-reviews-dim">(12)</span>
                  </div>
                  <div class="gmap-detail-dim">Aesthetic clinic · Shoreditch</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 1: Google Search results -->
        <div class="service-panel" data-panel="1">
          <div class="mock-card">
            <div class="serp-top">
              <div class="serp-searchbar">
                <svg class="serp-search-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="11" cy="11" r="7" stroke="#9ca3af" stroke-width="2"/>
                  <line x1="16.5" y1="16.5" x2="21" y2="21" stroke="#9ca3af" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <span class="serp-query">best aesthetic clinic london</span>
              </div>
              <div class="serp-stats">About 892,000 results (0.43 seconds)</div>
            </div>
            <div class="serp-results">
              <div class="serp-result serp-result-top">
                <span class="serp-rank">#1</span>
                <div class="serp-url-line">
                  <span class="serp-favicon"></span>
                  <span class="serp-url">timeout.com<span class="serp-url-path"> › best-aesthetic-clinics</span></span>
                </div>
                <div class="serp-title">The best aesthetic clinics in London</div>
                <div class="serp-desc">Aster Aesthetics tops our list for natural-looking results and aftercare. The Marylebone clinic books out weeks ahead, and it shows why.</div>
              </div>
              <div class="serp-result serp-result-2">
                <div class="serp-url-line">
                  <span class="serp-favicon dim"></span>
                  <span class="serp-url dim">trustpilot.com</span>
                </div>
                <div class="serp-title">Aster Aesthetics reviews</div>
                <div class="serp-desc">Rated excellent by 89 clients. Read what patients say about consultations, results, and aftercare...</div>
              </div>
              <div class="serp-result serp-result-3">
                <div class="serp-url-line">
                  <span class="serp-favicon dim"></span>
                  <span class="serp-url">harleystreet directory</span>
                </div>
                <div class="serp-title">Aster Aesthetics: verified practitioner listing</div>
                <div class="serp-desc">Registered aesthetic clinic in Marylebone. Credentials, treatments, and booking information...</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Panel 0: AI search response (ChatGPT) -->
        <div class="service-panel active" data-panel="0">
          <div class="mock-card chatgpt-card">
            <div class="cg-label">AI SEARCH RESPONSE</div>
            <div class="cg-question">Who is the best clinic for lip filler in London?</div>
            <div class="cg-response">
              <div class="cg-head">
                <span class="cg-avatar">AI</span>
                <span class="cg-name">ChatGPT</span>
              </div>
              <div class="cg-text">Based on reviews and press coverage, I'd recommend <strong>Aster Aesthetics</strong> in Marylebone. They are consistently praised for natural-looking results, hold a 4.9 rating across 89 reviews, and offer online booking with a free consultation.</div>
            </div>
            <div class="cg-sources">
              <span class="cg-sources-label">SOURCES</span>
              <span class="cg-source">timeout.com ↗</span>
              <span class="cg-source">trustpilot.com ↗</span>
            </div>
          </div>
        </div>

        <!-- Panel 3: citation tracking report -->
        <div class="service-panel" data-panel="3">
          <div class="mock-card voice-card">
            <div class="vc-header">
              <div class="vc-label">CITATION TRACKING</div>
              <div class="vc-active"><span class="vc-dot"></span>Monthly report</div>
              <div class="vc-caller">12 tracked queries</div>
            </div>
            <div class="vc-transcript">
              <div class="vc-msg">
                <div class="vc-msg-label vc-ai">CHATGPT</div>
                <div class="vc-msg-text">Cited for 7 of 12 tracked queries</div>
              </div>
              <div class="vc-msg">
                <div class="vc-msg-label vc-ai">PERPLEXITY</div>
                <div class="vc-msg-text">Cited for 5 of 12 tracked queries</div>
              </div>
              <div class="vc-msg">
                <div class="vc-msg-label vc-ai">GOOGLE AI OVERVIEWS</div>
                <div class="vc-msg-text">Appearing for 3 queries, up from 1 last month</div>
              </div>
            </div>
            <div class="vc-status">FULL REPORT · FIRST MONDAY OF THE MONTH</div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  #services {
    position: relative;
    z-index: 1;
    background: transparent;
    /* NOTE: no `overflow: hidden` here — it would break the sticky-tabs
       (position: sticky needs no clipping ancestor). The glow below is
       inset:0, so it stays within the section bounds without clipping. */
  }

  /* Decorative lavender-plum glow: very subtle, sits behind all content.
     inset:0 so it stays within the section bounds; invisible on dark body. */
  .services-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(ellipse 90% 60% at 50% 35%, rgba(196, 181, 253, 0.35) 0%, rgba(95, 75, 139, 0.12) 45%, transparent 75%);
  }

  /* ---- Header ---- */
  .services-header {
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    padding: 6rem 1.5rem 3rem;
  }
  .services-header .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #5F4B8B;
  }
  .services-header h2 {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.15;
    color: #1a1a1f;
    margin-top: 1rem;
  }
  .services-subtext {
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    color: #6b7280;
    line-height: 1.7;
    margin-top: 1rem;
  }

  /* ---- Blurred-stagger reveal: per-letter blur(10px)->0 + fade, staggered ---- */
  .bs-char {
    opacity: 0;
    filter: blur(10px);
  }
  .services-header.is-visible .bs-char {
    animation: bs-blur-in 0.3s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--bs-base, 0s) + var(--bs-i) * 0.015s);
  }
  @keyframes bs-blur-in {
    to {
      opacity: 1;
      filter: blur(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .bs-char { opacity: 1; filter: none; animation: none; }
  }

  /* ---- Scroll-driven container ---- */
  .services-scroll-container {
    position: relative;
    z-index: 1;
    height: 375vh;
  }
  .services-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    gap: 3rem;
    max-width: 1140px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ---- Left: nav labels + active copy + CTA ---- */
  .services-left {
    width: 42%;
    display: flex;
    flex-direction: column;
  }
  .services-nav {
    margin-bottom: 1.5rem;
  }
  .service-label {
    all: unset;
    cursor: pointer;
    display: block;
    width: 100%;
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.2;
    padding: 0.85rem 0;
    color: #6b7280;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1), padding-left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: left;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }
  .service-label:first-child {
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .service-label.active {
    color: #1a1a1f;
    padding-left: 6px;
  }
  .service-label.active::before {
    content: '';
    display: inline-block;
    width: 3px;
    height: 1em;
    background: #5F4B8B;
    border-radius: 2px;
    margin-right: 10px;
    vertical-align: middle;
  }
  .service-label:hover:not(.active) {
    color: #374151;
  }

  /* Copies share a single grid cell so the container auto-sizes to the
     tallest copy (no absolute overflow), keeping the CTA clear of the text. */
  .service-copy-container {
    display: grid;
    margin-bottom: 1.5rem;
  }
  .service-copy {
    grid-area: 1 / 1;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    visibility: hidden;
    padding-top: 1.25rem;
  }
  .service-copy.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }
  .service-q {
    font-family: 'Fraunces Variable', 'Fraunces', Georgia, serif;
    font-weight: 400;
    font-size: 1.1rem;
    color: #1a1a1f;
    line-height: 1.25;
    margin: 0 0 0.85rem;
  }
  .pain {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .fix {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    color: #1a1a1f;
    font-weight: 500;
    line-height: 1.65;
    margin-bottom: 0.75rem;
  }
  .stat {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: #6b7280;
    font-style: italic;
    line-height: 1.6;
  }
  .stat-num {
    color: #5F4B8B;
    font-weight: 600;
    font-style: normal;
  }

  .services-cta {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #5F4B8B;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.3s;
    min-height: 44px;
  }
  .services-cta:hover { opacity: 0.7; }

  /* ---- Right: mock card panels ---- */
  .services-right {
    width: 53%;
    position: relative;
    min-height: 500px;
  }
  .service-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.45s cubic-bezier(0.16, 1, 0.3, 1), transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
    visibility: hidden;
  }
  .service-panel.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  /* ---- Mock card (shared) ---- */
  .mock-card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.04);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  @media (hover: hover) {
    .mock-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.06);
    }
  }

  /* ---- Card 0: Google Maps pack ---- */
  .gmap {
    position: relative;
    height: 180px;
    background: #E8F5E9;
    overflow: hidden;
  }
  .gmap-road {
    position: absolute;
    background: rgba(255,255,255,0.7);
  }
  .gmap-road-h1 { left: 0; right: 0; top: 30%; height: 3px; }
  .gmap-road-h2 { left: 0; right: 0; top: 65%; height: 3px; }
  .gmap-road-v1 { top: 0; bottom: 0; left: 30%; width: 3px; }
  .gmap-road-v2 { top: 0; bottom: 0; left: 65%; width: 3px; }
  .gmap-pin {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 30px;
    transform: translate(-50%, -100%);
  }
  .gmap-pin-head {
    position: absolute;
    top: 0;
    left: 50%;
    width: 22px;
    height: 22px;
    margin-left: -11px;
    background: #EA4335;
    border-radius: 50% 50% 50% 0;
    transform: rotate(45deg);
    box-shadow: 0 2px 8px rgba(234,67,53,0.4);
  }
  .gmap-pin-head::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    background: #fff;
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }
  .gmap-ping {
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 12px;
    height: 12px;
    margin-left: -6px;
    border-radius: 50%;
    background: rgba(234,67,53,0.45);
    animation: ping 2s ease-out infinite;
  }
  @keyframes ping {
    0% { transform: scale(1); opacity: 0.4; }
    100% { transform: scale(1.8); opacity: 0; }
  }
  .gmap-attribution {
    position: absolute;
    left: 6px;
    bottom: 4px;
    font-family: 'Inter Variable', sans-serif;
    font-size: 9px;
    color: rgba(0,0,0,0.3);
  }
  .gmap-listings { padding: 1.25rem; }
  .gmap-listing {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }
  .gmap-listing:last-child { border-bottom: none; }
  .gmap-listing.highlighted {
    background: #F0F7FF;
    border-radius: 8px;
    padding: 0.75rem;
    margin: 0 -0.5rem;
    border-bottom: none;
  }
  .gmap-rank {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 12px;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .highlighted .gmap-rank { background: #5F4B8B; color: #fff; }
  .dim .gmap-rank { background: #E5E7EB; color: #6b7280; }
  .more-dim .gmap-rank { background: #E5E7EB; color: #9ca3af; }
  .gmap-name {
    font-family: 'Inter Variable', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1f;
  }
  .dim .gmap-name { font-size: 14px; font-weight: 500; color: #6b7280; }
  .more-dim .gmap-name { font-size: 14px; font-weight: 500; color: #9ca3af; }
  .gmap-rating-line {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 2px;
  }
  .gmap-score { font-family: 'Inter Variable', sans-serif; font-size: 13px; font-weight: 600; color: #1a1a1f; }
  .gmap-stars { color: #FBBF24; font-size: 13px; }
  .gmap-reviews { font-family: 'Inter Variable', sans-serif; font-size: 13px; color: #6b7280; }
  .gmap-score-dim, .gmap-reviews-dim { font-family: 'Inter Variable', sans-serif; font-size: 12px; color: #9ca3af; }
  .gmap-stars-dim { color: #D1D5DB; font-size: 12px; }
  .gmap-detail { font-family: 'Inter Variable', sans-serif; font-size: 13px; color: #6b7280; margin-top: 2px; }
  .gmap-detail-dim { font-family: 'Inter Variable', sans-serif; font-size: 12px; color: #9ca3af; margin-top: 2px; }
  .gmap-status {
    display: flex;
    align-items: center;
    font-family: 'Inter Variable', sans-serif;
    font-size: 12px;
    color: #22C55E;
    margin-top: 3px;
  }
  .gmap-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22C55E;
    margin-right: 5px;
    display: inline-block;
  }

  /* ---- Card 1: Google Search results ---- */
  .serp-top { padding: 1.25rem 1.25rem 0; }
  .serp-searchbar {
    position: relative;
    background: #F1F3F4;
    border-radius: 24px;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    display: flex;
    align-items: center;
  }
  .serp-search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
  }
